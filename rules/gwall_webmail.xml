<!--
  Great Wall — Node.js Webmail Application Rules
  YUL CYBERHUB · MEQ7 Team 3
  Rule IDs: 100300-100399
  File: /var/ossec/etc/rules/gwall_webmail.xml
-->

<group name="gwall,webmail,">

  <rule id="100300" level="10" frequency="10" timeframe="60">
    <if_matched_sid>100002</if_matched_sid>
    <match>/api/login|/login|/auth</match>
    <same_source_ip/>
    <description>Webmail: Login endpoint brute force - 10+ failures in 60 seconds</description>
    <group>web,auth_failure,brute_force,</group>
  </rule>

  <rule id="100301" level="10">
    <if_sid>31101</if_sid>
    <match>:3000</match>
    <description>Webmail: Direct access to Node.js port 3000 - firewall bypass attempt</description>
    <group>web,attack,</group>
  </rule>

  <rule id="100302" level="9">
    <if_sid>1002</if_sid>
    <match>PM2|pm2.*restart|app crashed|restart.*count|process.*exited</match>
    <description>Webmail: Node.js application crash detected via PM2</description>
    <group>web,error,</group>
  </rule>

  <rule id="100303" level="7">
    <if_sid>31101</if_sid>
    <match>CORS|Access-Control|Cross-Origin</match>
    <description>Webmail: CORS policy violation detected</description>
    <group>web,attack,</group>
  </rule>

</group>

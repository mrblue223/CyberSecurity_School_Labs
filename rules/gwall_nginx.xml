<!--
  Great Wall — Nginx Web Server Rules
  YUL CYBERHUB · MEQ7 Team 3
  Rule IDs: 100001-100099
  File: /var/ossec/etc/rules/gwall_nginx.xml
-->

<group name="gwall,nginx,">

  <rule id="100001" level="4">
    <if_sid>31101</if_sid>
    <match>HTTP/\d.\d" 400</match>
    <description>Nginx: Bad request (400) - malformed client request</description>
    <group>web,</group>
  </rule>

  <rule id="100002" level="7">
    <if_sid>31101</if_sid>
    <match>HTTP/\d.\d" 401</match>
    <description>Nginx: Unauthorized access attempt (401)</description>
    <group>web,auth_failure,</group>
  </rule>

  <rule id="100003" level="7">
    <if_sid>31101</if_sid>
    <match>HTTP/\d.\d" 403</match>
    <description>Nginx: Forbidden access attempt (403)</description>
    <group>web,attack,</group>
  </rule>

  <rule id="100004" level="3">
    <if_sid>31101</if_sid>
    <match>HTTP/\d.\d" 404</match>
    <description>Nginx: Resource not found (404)</description>
    <group>web,</group>
  </rule>

  <rule id="100005" level="8">
    <if_sid>31101</if_sid>
    <match>HTTP/\d.\d" 429</match>
    <description>Nginx: Rate limit exceeded (429) - possible DDoS or scraping</description>
    <group>web,attack,dos,</group>
  </rule>

  <rule id="100006" level="7">
    <if_sid>31101</if_sid>
    <match>HTTP/\d.\d" 500</match>
    <description>Nginx: Internal server error (500)</description>
    <group>web,error,</group>
  </rule>

  <rule id="100007" level="6">
    <if_sid>31101</if_sid>
    <match>HTTP/\d.\d" 502</match>
    <description>Nginx: Bad gateway (502) - upstream service failure</description>
    <group>web,error,</group>
  </rule>

  <rule id="100008" level="8">
    <if_sid>31101</if_sid>
    <match>HTTP/\d.\d" 503</match>
    <description>Nginx: Service unavailable (503) - possible overload or DoS</description>
    <group>web,error,dos,</group>
  </rule>

  <rule id="100010" level="13">
    <if_sid>31101</if_sid>
    <match>select%20|union%20|insert%20|drop%20|delete%20|update%20|exec%20|cast%28|convert%28|xp_|sp_|0x|%27|%3B--|information_schema|sysobjects|syscolumns</match>
    <description>Nginx: SQL injection attempt detected in URL</description>
    <group>web,attack,sql_injection,</group>
  </rule>

  <rule id="100011" level="13">
    <if_sid>31101</if_sid>
    <match>%3Cscript|javascript:|vbscript:|onerror=|onload=|onmouseover=|alert%28|document\.cookie|document\.write|eval%28|fromcharcode|innerHTML|outerHTML</match>
    <description>Nginx: Cross-site scripting (XSS) attempt detected</description>
    <group>web,attack,xss,</group>
  </rule>

  <rule id="100012" level="13">
    <if_sid>31101</if_sid>
    <match>\.\.\/|\.\.\\|%2e%2e%2f|%2e%2e\/|\.\.%2f|%252e%252e|\.\.%5c|%c0%ae|%c1%9c</match>
    <description>Nginx: Directory traversal attempt detected</description>
    <group>web,attack,</group>
  </rule>

  <rule id="100013" level="13">
    <if_sid>31101</if_sid>
    <match>http://|https://|ftp://|php://|data://|expect://|zip://|glob://</match>
    <description>Nginx: Remote file inclusion (RFI) attempt detected</description>
    <group>web,attack,</group>
  </rule>

  <rule id="100014" level="13">
    <if_sid>31101</if_sid>
    <match>%7C|%3B|%60|%24%28|%7C%7C|;cat%20|;ls%20|;id%20|;whoami|;uname|;wget|;curl|;chmod|;bash|;sh%20|/etc/passwd|/etc/shadow|/proc/self</match>
    <description>Nginx: Command injection attempt detected in URL</description>
    <group>web,attack,command_injection,</group>
  </rule>

  <rule id="100015" level="8">
    <if_sid>31101</if_sid>
    <regex>nikto|sqlmap|nmap|masscan|zgrab|gobuster|dirbuster|wfuzz|ffuf|hydra|metasploit|burpsuite|acunetix|nessus|openvas|w3af|skipfish|havij</regex>
    <description>Nginx: Known web scanner or attack tool detected in user-agent</description>
    <group>web,attack,recon,</group>
  </rule>

  <rule id="100016" level="10">
    <if_sid>31101</if_sid>
    <match>client_max_body_size|request entity too large|413</match>
    <description>Nginx: Oversized request body - possible buffer overflow attempt</description>
    <group>web,attack,</group>
  </rule>

  <rule id="100017" level="15">
    <if_sid>31101</if_sid>
    <match>169.254.169.254|metadata.internal|169.254.170.2</match>
    <description>Nginx: SSRF attempt targeting AWS EC2 metadata service</description>
    <group>web,attack,ssrf,aws,</group>
  </rule>

  <rule id="100018" level="5">
    <if_sid>31108</if_sid>
    <match>connect() failed|Connection refused|upstream</match>
    <description>Nginx: Upstream connection failure - backend service may be down</description>
    <group>web,error,</group>
  </rule>

  <rule id="100019" level="6">
    <if_sid>31108</if_sid>
    <match>SSL_do_handshake|no shared cipher|unknown protocol|tlsv1 alert|ssl handshake failure</match>
    <description>Nginx: TLS/SSL handshake failure - possible downgrade attack</description>
    <group>web,tls,</group>
  </rule>

  <rule id="100020" level="11" frequency="8" timeframe="60">
    <if_matched_sid>100002</if_matched_sid>
    <same_source_ip/>
    <description>Nginx: Web brute force - 8+ unauthorized attempts in 60 seconds</description>
    <group>web,auth_failure,brute_force,</group>
  </rule>

  <rule id="100021" level="10" frequency="20" timeframe="60">
    <if_matched_sid>100004</if_matched_sid>
    <same_source_ip/>
    <description>Nginx: Possible web scanning - 20+ 404s in 60 seconds from same IP</description>
    <group>web,recon,</group>
  </rule>

  <rule id="100022" level="12" frequency="100" timeframe="10">
    <if_matched_sid>31101</if_matched_sid>
    <same_source_ip/>
    <description>Nginx: Possible DoS attack - 100+ requests in 10 seconds from same IP</description>
    <group>web,dos,attack,</group>
  </rule>

</group>

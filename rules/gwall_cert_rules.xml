<group name="gwall,pki,certificates,">

  <!-- Wazuh Manager - PKI renewal rules -->
  <rule id="100001" level="12">
    <program_name>renew-gwall-certs</program_name>
    <match>ERROR: Failed to generate</match>
    <description>Great Wall PKI: Certificate renewal FAILED</description>
    <group>pki_failure,certificate_error,</group>
  </rule>

  <rule id="100002" level="12">
    <program_name>renew-gwall-certs</program_name>
    <match>ERROR: securityadmin failed</match>
    <description>Great Wall PKI: securityadmin failed after cert renewal</description>
    <group>pki_failure,certificate_error,</group>
  </rule>

  <rule id="100003" level="10">
    <program_name>renew-gwall-certs</program_name>
    <match>ERROR: CRL regeneration failed</match>
    <description>Great Wall PKI: CRL regeneration failed</description>
    <group>pki_failure,</group>
  </rule>

  <rule id="100004" level="3">
    <program_name>renew-gwall-certs</program_name>
    <match>renewed successfully</match>
    <description>Great Wall PKI: Certificate renewed successfully</description>
    <group>pki_info,</group>
  </rule>

  <!-- Frontend - Let's Encrypt cert monitoring -->
  <rule id="100010" level="10">
    <program_name>check-gwall-frontend-certs</program_name>
    <match>WARNING: Let's Encrypt cert expires in</match>
    <description>Great Wall Frontend: Let's Encrypt cert expiring within 30 days</description>
    <group>pki_warning,certificate_expiry,</group>
  </rule>

  <rule id="100011" level="14">
    <program_name>check-gwall-frontend-certs</program_name>
    <match>CRITICAL: Let's Encrypt cert expires in</match>
    <description>Great Wall Frontend: Let's Encrypt cert expiring within 14 days - URGENT</description>
    <group>pki_critical,certificate_expiry,</group>
  </rule>

  <rule id="100012" level="14">
    <program_name>check-gwall-frontend-certs</program_name>
    <match>CRITICAL: certbot-renew.timer is NOT active</match>
    <description>Great Wall Frontend: Auto-renewal timer broken - manual renewal required</description>
    <group>pki_critical,certificate_error,</group>
  </rule>

  <rule id="100013" level="12">
    <program_name>check-gwall-frontend-certs</program_name>
    <match>ERROR: Could not retrieve certificate from</match>
    <description>Great Wall Frontend: Cannot connect to service to check certificate</description>
    <group>pki_failure,service_down,</group>
  </rule>

  <rule id="100014" level="12">
    <program_name>check-gwall-frontend-certs</program_name>
    <match>CRITICAL: Nginx cert</match>
    <description>Great Wall Frontend: Nginx certificate expiring within 14 days</description>
    <group>pki_critical,certificate_expiry,</group>
  </rule>

  <rule id="100015" level="12">
    <program_name>check-gwall-frontend-certs</program_name>
    <match>CRITICAL: Postfix SMTPS cert</match>
    <description>Great Wall Frontend: Postfix SMTPS certificate expiring within 14 days</description>
    <group>pki_critical,certificate_expiry,</group>
  </rule>

  <rule id="100016" level="12">
    <program_name>check-gwall-frontend-certs</program_name>
    <match>CRITICAL: Dovecot IMAPS cert</match>
    <description>Great Wall Frontend: Dovecot IMAPS certificate expiring within 14 days</description>
    <group>pki_critical,certificate_expiry,</group>
  </rule>

</group>

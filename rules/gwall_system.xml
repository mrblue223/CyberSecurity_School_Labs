<!--
  Great Wall — System and AWS Security Rules
  YUL CYBERHUB · MEQ7 Team 3
  Rule IDs: 100600-100699
  File: /var/ossec/etc/rules/gwall_system.xml
-->

<group name="gwall,system,">

  <rule id="100600" level="12">
    <if_sid>31101</if_sid>
    <url_match>169.254.169.254</url_match>
    <description>System: AWS EC2 metadata service access attempt - possible SSRF</description>
    <group>aws,ssrf,attack,</group>
  </rule>

  <rule id="100601" level="11">
    <if_sid>531</if_sid>
    <match>No space left on device|disk full|ENOSPC</match>
    <description>System: Disk space exhausted - service degradation likely</description>
    <group>system,error,</group>
  </rule>

  <rule id="100603" level="10">
    <if_sid>2904</if_sid>
    <match>nginx|postfix|dovecot|wazuh|wireguard</match>
    <description>System: Critical service stopped unexpectedly</description>
    <group>system,error,</group>
  </rule>

  <rule id="100604" level="9">
    <if_sid>5902</if_sid>
    <description>System: New user account created - verify this is authorized</description>
    <group>system,account,</group>
  </rule>

  <rule id="100605" level="10">
    <if_sid>5903</if_sid>
    <match>sudo|wheel|admin|root</match>
    <description>System: User added to privileged group - privilege escalation risk</description>
    <group>system,account,privilege_escalation,</group>
  </rule>

  <rule id="100606" level="11">
    <if_sid>550</if_sid>
    <field name="file">/etc/firewalld</field>
    <description>System: Firewalld configuration modified</description>
    <group>system,firewall,config_changed,</group>
  </rule>

  <rule id="100608" level="7">
    <if_sid>1002</if_sid>
    <match>Failed to start|systemd.*failed|Unit.*failed|service failed</match>
    <description>System: systemd service failure detected</description>
    <group>system,error,</group>
  </rule>

  <rule id="100609" level="12">
    <if_sid>1002</if_sid>
    <match>certbot.*error|certbot.*fail|renewal.*failed|certificate.*expired|ACME.*error</match>
    <description>System: SSL certificate renewal failure - certificate may expire soon</description>
    <group>system,tls,error,</group>
  </rule>

  <rule id="100610" level="3">
    <if_sid>1002</if_sid>
    <match>certbot.*success|Congratulations|renewal.*success|certificate.*renewed</match>
    <description>System: SSL certificate successfully renewed</description>
    <group>system,tls,</group>
  </rule>

</group>

<!--
  Great Wall — Postfix Mail Server Rules
  YUL CYBERHUB · MEQ7 Team 3
  Rule IDs: 100100-100199
  File: /var/ossec/etc/rules/gwall_postfix.xml
-->

<group name="gwall,postfix,">

  <rule id="100100" level="6">
    <if_sid>3300</if_sid>
    <match>authentication failed|SASL LOGIN authentication failed|SASL PLAIN authentication failed</match>
    <description>Postfix: SMTP authentication failure</description>
    <group>mail,auth_failure,</group>
  </rule>

  <rule id="100101" level="11" frequency="6" timeframe="120">
    <if_matched_sid>100100</if_matched_sid>
    <same_source_ip/>
    <description>Postfix: SMTP brute force - 6+ auth failures in 120 seconds</description>
    <group>mail,auth_failure,brute_force,</group>
  </rule>

  <rule id="100102" level="9">
    <if_sid>3300</if_sid>
    <match>Relay access denied</match>
    <description>Postfix: Open relay attempt blocked</description>
    <group>mail,attack,</group>
  </rule>

  <rule id="100103" level="5">
    <if_sid>3300</if_sid>
    <match>Connection refused|connect to|Network is unreachable</match>
    <description>Postfix: Outbound SMTP connection failure</description>
    <group>mail,error,</group>
  </rule>

  <rule id="100104" level="8" frequency="10" timeframe="60">
    <if_sid>3300</if_sid>
    <match>status=bounced|bounced back</match>
    <description>Postfix: High bounce rate - possible backscatter or spam</description>
    <group>mail,attack,spam,</group>
  </rule>

  <rule id="100105" level="7">
    <if_sid>3300</if_sid>
    <match>SPF.*fail|SPF.*softfail|Received-SPF: fail|Received-SPF: softfail</match>
    <description>Postfix: Inbound email failed SPF check</description>
    <group>mail,spf,</group>
  </rule>

  <rule id="100106" level="7">
    <if_sid>3300</if_sid>
    <match>DKIM.*fail|DKIM.*invalid|opendkim.*fail|signature verification failed</match>
    <description>Postfix: Inbound email failed DKIM verification</description>
    <group>mail,dkim,</group>
  </rule>

  <rule id="100107" level="8">
    <if_sid>3300</if_sid>
    <match>DMARC.*fail|DMARC.*reject|p=reject.*fail</match>
    <description>Postfix: Inbound email failed DMARC policy</description>
    <group>mail,dmarc,</group>
  </rule>

  <rule id="100108" level="7">
    <if_sid>3300</if_sid>
    <match>deferred</match>
    <description>Postfix: Deferred mail detected - possible delivery issue</description>
    <group>mail,error,</group>
  </rule>

  <rule id="100109" level="6">
    <if_sid>3300</if_sid>
    <match>TLS.*failed|SSL.*error|Cannot start TLS|STARTTLS.*failed</match>
    <description>Postfix: TLS negotiation failure on SMTP connection</description>
    <group>mail,tls,</group>
  </rule>

  <rule id="100110" level="10">
    <if_sid>3300</if_sid>
    <match>blocked using|reject.*spam|reject.*virus|reject.*malware|RBL|DNSBL|blacklist</match>
    <description>Postfix: Email rejected by content filter or blacklist</description>
    <group>mail,spam,</group>
  </rule>

  <rule id="100111" level="5">
    <if_sid>3300</if_sid>
    <match>smtp.sendgrid.net|fallback_relay</match>
    <description>Postfix: SendGrid fallback relay activated - direct SMTP failed</description>
    <group>mail,</group>
  </rule>

  <rule id="100112" level="10" frequency="30" timeframe="60">
    <if_sid>3300</if_sid>
    <same_source_ip/>
    <description>Postfix: High SMTP connection rate from single IP - possible spam bot</description>
    <group>mail,dos,</group>
  </rule>

</group>

<!--
  Great Wall — File Integrity Monitoring Rules
  YUL CYBERHUB · MEQ7 Team 3
  Rule IDs: 100500-100599
  File: /var/ossec/etc/rules/gwall_fim.xml
-->

<group name="gwall,fim,">

  <rule id="100500" level="10">
    <if_sid>550</if_sid>
    <field name="file">/etc/nginx</field>
    <description>FIM: Nginx configuration file modified</description>
    <group>syscheck,config_changed,</group>
  </rule>

  <rule id="100501" level="10">
    <if_sid>550</if_sid>
    <field name="file">/etc/postfix</field>
    <description>FIM: Postfix configuration file modified</description>
    <group>syscheck,config_changed,</group>
  </rule>

  <rule id="100502" level="10">
    <if_sid>550</if_sid>
    <field name="file">/etc/dovecot</field>
    <description>FIM: Dovecot configuration file modified</description>
    <group>syscheck,config_changed,</group>
  </rule>

  <rule id="100503" level="9">
    <if_sid>550</if_sid>
    <field name="file">/etc/letsencrypt</field>
    <description>FIM: SSL/TLS certificate or key file modified</description>
    <group>syscheck,tls,</group>
  </rule>

  <rule id="100504" level="12">
    <if_sid>550</if_sid>
    <field name="file">/etc/wireguard</field>
    <description>FIM: WireGuard configuration modified - verify peer changes are authorized</description>
    <group>syscheck,config_changed,vpn,</group>
  </rule>

  <rule id="100505" level="13">
    <if_sid>550</if_sid>
    <field name="file">/etc/ssh|authorized_keys|known_hosts</field>
    <description>FIM: SSH configuration or key file modified - possible backdoor installation</description>
    <group>syscheck,config_changed,ssh,</group>
  </rule>

  <rule id="100506" level="12">
    <if_sid>550</if_sid>
    <field name="file">/var/ossec/etc</field>
    <description>FIM: Wazuh agent configuration modified</description>
    <group>syscheck,config_changed,</group>
  </rule>

  <rule id="100507" level="10">
    <if_sid>550</if_sid>
    <field name="file">/var/www</field>
    <description>FIM: Web root file modified - verify no unauthorized content change</description>
    <group>syscheck,web,</group>
  </rule>

  <rule id="100508" level="11">
    <if_sid>550</if_sid>
    <field name="file">/etc/cron|/var/spool/cron</field>
    <description>FIM: Cron job modified - possible persistence mechanism installed</description>
    <group>syscheck,config_changed,</group>
  </rule>

  <rule id="100509" level="14">
    <if_sid>550</if_sid>
    <field name="file">/usr/bin|/usr/sbin|/bin|/sbin</field>
    <description>FIM: System binary modified - possible rootkit or trojan installation</description>
    <group>syscheck,rootkit,</group>
  </rule>

  <rule id="100510" level="12">
    <if_sid>554</if_sid>
    <field name="file">/var/www</field>
    <description>FIM: New file created in web root - verify it is not a web shell</description>
    <group>syscheck,web,</group>
  </rule>

  <rule id="100511" level="15">
    <if_sid>554</if_sid>
    <field name="perm">^[0-9]{0,1}[46][0-9]{3}$</field>
    <description>FIM: New SUID/SGID file created - critical privilege escalation risk</description>
    <group>syscheck,rootkit,privilege_escalation,</group>
  </rule>

</group>
